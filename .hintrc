{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-viewport": "off",
    "no-inline-styles": "off",
    "axe/text-alternatives": [
      "default",
      {
        "image-alt": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scrollbar-width",
          "scrollbar-width: none",
          "text-size-adjust",
          "-webkit-user-drag",
          "text-size-adjust: none"
        ]
      }
    ],
    "css-prefix-order": "off"
  }
}